# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Ignore everything by default
*

# Whitelist specific files in the root only
!/.gitignore
!/README.md
!/docker-compose.yml
!/update.sh
!/.env
!/global.env
!/global.update.sh

# Explicitly ignore all directories and their content
# This ensures that any future config folder stays local-only
/*/

# Security: Ensure secret local envs never get tracked
.env.local
.env.*.local
*.log
.DS_Store

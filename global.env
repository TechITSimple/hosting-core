# /home/tis/websites/.env

# SYSTEM-WIDE CONFIGURATION
# These variables are shared across all satellite containers.
# This file is automatically copied to the parent directory by update.sh.

# Timezone for logs and system processes
TZ=Europe/Rome

# User and Group IDs (1000 for the first non-root user 'tis')
PUID=1000
PGID=1000

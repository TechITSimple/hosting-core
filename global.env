# /home/tis/websites/[environment-name]/.env

# SYSTEM-WIDE CONFIGURATION
# These variables are shared across all satellite containers within this macro-environment.
# This file is automatically copied to the parent directory by global.update.sh.

# Timezone for logs and system processes
TZ=Europe/Rome

# User and Group IDs
# PUID is typically 1000 (the 'tis' user).
# PGID should match the GID of the shared 'web-admins' group to ensure correct file ownership.
PUID=1000
PGID=1003
